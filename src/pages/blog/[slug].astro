---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const SITE_URL = 'https://unamarca.com.ar';
// Explicit trailing slash: Cloudflare Pages serves dist/blog/slug/index.html at /blog/slug/
const canonicalURL = `${SITE_URL}/blog/${post.id}/`;
const pubDateISO = post.data.pubDate.toISOString();

function formatDate(date: Date): string {
  return date.toLocaleDateString('es-AR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: pubDateISO,
  dateModified: pubDateISO,
  url: canonicalURL,
  inLanguage: 'es-AR',
  author: {
    '@type': 'Organization',
    name: 'UnaMarca',
    url: SITE_URL,
  },
  publisher: {
    '@type': 'Organization',
    name: 'UnaMarca',
    url: SITE_URL,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalURL,
  },
};
---

<BaseLayout
  title={`${post.data.title} | UnaMarca`}
  description={post.data.description}
  canonicalURL={canonicalURL}
  type="article"
  pubDate={pubDateISO}
  tags={post.data.tags}
  structuredData={structuredData}
>
  <article class="blog-post">
    <div class="container">
      <header class="post-header">
        <div class="post-meta">
          <time datetime={pubDateISO}>
            {formatDate(post.data.pubDate)}
          </time>
          {post.data.tags && post.data.tags.length > 0 && (
            <ul class="tag-list" role="list">
              {post.data.tags.map(tag => (
                <li class="tag">{tag}</li>
              ))}
            </ul>
          )}
        </div>
        <h1>{post.data.title}</h1>
        <p class="post-description">{post.data.description}</p>
      </header>

      <div class="prose">
        <Content />
      </div>

      <aside class="post-cta" aria-label="Registrá tu marca">
        <h2>Registrá tu marca 100% online</h2>
        <p>
          Precio fijo y sin vueltas: completás los datos, firmás la carta poder
          digital y presentamos tu solicitud ante el INPI dentro de las 48 horas hábiles.
        </p>
        <div class="post-cta-actions">
          <a href="/registrar" class="btn btn-white" onclick="gtag('event', 'registrar_click', {'source': 'blog'})">
            Empezar mi registro
          </a>
          <a
            href="https://wa.me/5491149712224?text=Hola%2C%20tom%C3%A9%20su%20contacto%20de%20la%20web%20y%20quer%C3%ADa%20consultar%20por%20el%20servicio%20de%20registro%20de%20marcas!"
            class="post-cta-wa"
            target="_blank"
            rel="noopener noreferrer"
            onclick="gtag('event', 'whatsapp_click')"
          >o consultanos por WhatsApp</a>
        </div>
      </aside>

      <footer class="post-footer">
        <a href="/blog" class="back-link">← Volver al blog</a>
      </footer>
    </div>
  </article>
</BaseLayout>
