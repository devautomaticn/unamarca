---
// Self-checkout de registro de marca — v1 (spec: docs/spec_self_checkout.md)
// Pago: placeholder (sin Mercado Pago). Envío: simulado en esta fase de UX —
// TODO wiring: POST /api/checkout/submit (PDF + emails).
import BaseLayout from '../layouts/BaseLayout.astro';
import { NIZA_CLASSES } from '../lib/checkout/nizaClasses';
import { PRICING, PROVINCIAS, waUrl, formatARS } from '../lib/checkout/constants';

const SITE_URL = 'https://unamarca.com.ar';

const waEmpresa = waUrl('Hola! Quiero registrar una marca a nombre de una empresa (persona jurídica).');
const waClase = waUrl('Hola! Estoy registrando mi marca en unamarca.com.ar y no sé qué clase elegir.');
const waMulti = waUrl('Hola! Quiero registrar una marca en más de una clase.');
---

<BaseLayout
  title="Registrá tu Marca Online | UnaMarca"
  description="Solicitá el registro de tu marca ante el INPI en minutos: elegí la clase, completá tus datos y firmá online. Simple, rápido y sin vueltas."
  canonicalURL={`${SITE_URL}/registrar`}
  noindex
>

<div class="ck-page">
  <div class="ck-wrap">

    <header class="ck-header">
      <div class="ck-badge">
        <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M8 1.5L2.5 4v4c0 3.2 2.4 5.8 5.5 6.5 3.1-.7 5.5-3.3 5.5-6.5V4L8 1.5z" fill="currentColor"/></svg>
        Registro online · INPI Argentina
      </div>
      <h1>Registrá tu marca</h1>
      <p>Completá tu solicitud en unos minutos. Nosotros la presentamos ante el INPI.</p>
    </header>

    <div class="ck-progress" id="ck-progress">
      <div class="ck-progress-top">
        <span id="ck-step-label">Paso 1 de 5</span>
        <span id="ck-step-title">Tu marca</span>
      </div>
      <div class="ck-bar"><div class="ck-bar-fill" id="ck-bar-fill" style="width: 20%"></div></div>
    </div>

    <!-- ══════════ PASO 1 · TU MARCA ══════════ -->
    <section class="ck-step" data-step="1">
      <div class="ck-card">
        <div class="ck-section-label">Tu marca</div>

        <div class="ck-field">
          <label for="ck-marca">Nombre de la marca <em>*</em></label>
          <input type="text" id="ck-marca" placeholder="Ej: PASSIONARIA" autocomplete="off" maxlength="120" />
          <p class="ck-err" data-err="marca"></p>
        </div>

        <div class="ck-grid ck-g2">
          <div class="ck-field">
            <label for="ck-tipo-persona">Tipo de persona</label>
            <div class="ck-sel ck-sel--locked">
              <select id="ck-tipo-persona" disabled><option>Humana</option></select>
            </div>
            <p class="ck-help">¿Es para una empresa? <a href={waEmpresa} target="_blank" rel="noopener noreferrer">Escribinos por WhatsApp</a></p>
          </div>
          <div class="ck-field">
            <label for="ck-tipo-marca">Tipo de marca</label>
            <div class="ck-sel ck-sel--locked">
              <select id="ck-tipo-marca" disabled><option>Denominativa</option></select>
            </div>
            <p class="ck-help">Registramos el nombre de tu marca (sin logo).</p>
          </div>
        </div>

        <div class="ck-field">
          <label>Clase de productos o servicios <em>*</em></label>
          <div class="ck-dd" id="ck-clase-dd">
            <button type="button" class="ck-dd-btn" id="ck-clase-btn" aria-haspopup="listbox" aria-expanded="false">
              <span id="ck-clase-label" class="ck-dd-placeholder">Seleccioná la clase…</span>
              <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="#94a3b8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="ck-dd-panel" id="ck-clase-panel" hidden>
              <input type="text" id="ck-clase-search" placeholder="Buscar… (ej: ropa, café, software)" autocomplete="off" />
              <ul class="ck-dd-list" id="ck-clase-list" role="listbox">
                {NIZA_CLASSES.map(c => (
                  <li>
                    <button type="button" class="ck-dd-opt" data-num={c.num} role="option">
                      <span class="ck-dd-num">Clase {c.num}</span>
                      <span class="ck-dd-name">{c.nombre}</span>
                    </button>
                  </li>
                ))}
              </ul>
            </div>
          </div>
          <p class="ck-help">
            La clase define qué productos o servicios protege tu marca.
            ¿No sabés cuál elegir? <a href={waClase} target="_blank" rel="noopener noreferrer">Consultanos por WhatsApp</a>
            &nbsp;·&nbsp; <a href={waMulti} target="_blank" rel="noopener noreferrer">¿Necesitás más de una clase?</a>
          </p>
          <p class="ck-err" data-err="clase"></p>
        </div>
      </div>

      <div class="ck-nav">
        <span></span>
        <button type="button" class="ck-btn" data-next="1">
          Continuar
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </section>

    <!-- ══════════ PASO 2 · CONTACTO ══════════ -->
    <section class="ck-step" data-step="2" hidden>
      <div class="ck-card">
        <div class="ck-section-label">Tus datos de contacto</div>
        <div class="ck-grid ck-g2">
          <div class="ck-field">
            <label for="ck-email">Email <em>*</em></label>
            <input type="email" id="ck-email" placeholder="correo@ejemplo.com" autocomplete="email" />
            <p class="ck-help">Acá te enviaremos todas las novedades del trámite.</p>
            <p class="ck-err" data-err="email"></p>
          </div>
          <div class="ck-field">
            <label for="ck-whatsapp">WhatsApp <em>*</em></label>
            <input type="tel" id="ck-whatsapp" placeholder="11 5555 5555" autocomplete="tel" />
            <p class="ck-err" data-err="whatsapp"></p>
          </div>
        </div>
      </div>

      <div class="ck-nav">
        <button type="button" class="ck-back" data-back="1">← Volver</button>
        <button type="button" class="ck-btn" data-next="2">
          Continuar
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </section>

    <!-- ══════════ PASO 5 · DATOS DEL TITULAR (post-pago) ══════════ -->
    <section class="ck-step" data-step="5" hidden>
      <div id="ck-pay-banner" class="ck-banner" hidden></div>
      <div class="ck-card">
        <div class="ck-section-label">Datos del titular</div>
        <p class="ck-help" style="margin-bottom: 1rem">
          Ya casi está. Estos datos son necesarios para la carta poder y la
          presentación de tu solicitud ante el INPI.
        </p>

        <div class="ck-field">
          <label for="ck-nombre">Nombre y apellido <em>*</em></label>
          <input type="text" id="ck-nombre" placeholder="Tal como figura en tu DNI" autocomplete="name" />
          <p class="ck-help">Será la aclaración de tu firma en la carta poder.</p>
          <p class="ck-err" data-err="nombre"></p>
        </div>

        <div class="ck-grid ck-g2">
          <div class="ck-field">
            <label for="ck-dni">DNI <em>*</em></label>
            <input type="text" id="ck-dni" placeholder="22730331" inputmode="numeric" autocomplete="off" maxlength="8" />
            <p class="ck-err" data-err="dni"></p>
          </div>
          <div class="ck-field">
            <label for="ck-cuit">CUIT / CUIL <em>*</em></label>
            <input type="text" id="ck-cuit" placeholder="27-22730331-5" inputmode="numeric" autocomplete="off" maxlength="13" />
            <p class="ck-err" data-err="cuit"></p>
          </div>
        </div>

        <div class="ck-domicilio">
          <p class="ck-dom-title">Domicilio real</p>
          <div class="ck-grid ck-g2">
            <div class="ck-field">
              <label for="ck-calle">Calle <em>*</em></label>
              <input type="text" id="ck-calle" placeholder="Av. Corrientes" autocomplete="address-line1" />
              <p class="ck-err" data-err="calle"></p>
            </div>
            <div class="ck-field">
              <label for="ck-numero">Número <em>*</em></label>
              <input type="text" id="ck-numero" placeholder="1234" autocomplete="off" />
              <p class="ck-err" data-err="numero"></p>
            </div>
          </div>
          <div class="ck-grid ck-g2">
            <div class="ck-field">
              <label for="ck-piso">Piso</label>
              <input type="text" id="ck-piso" placeholder="3" autocomplete="off" />
            </div>
            <div class="ck-field">
              <label for="ck-depto">Depto</label>
              <input type="text" id="ck-depto" placeholder="A" autocomplete="off" />
            </div>
          </div>
          <div class="ck-grid ck-g2">
            <div class="ck-field">
              <label for="ck-localidad">Localidad <em>*</em></label>
              <input type="text" id="ck-localidad" placeholder="La Plata" autocomplete="address-level2" />
              <p class="ck-err" data-err="localidad"></p>
            </div>
            <div class="ck-field">
              <label for="ck-codpostal">Código postal <em>*</em></label>
              <input type="text" id="ck-codpostal" placeholder="1900" autocomplete="postal-code" />
              <p class="ck-err" data-err="codpostal"></p>
            </div>
          </div>
          <div class="ck-grid ck-g2">
            <div class="ck-field">
              <label for="ck-provincia">Provincia <em>*</em></label>
              <div class="ck-sel">
                <select id="ck-provincia">
                  <option value="">Seleccionar…</option>
                  {PROVINCIAS.map(p => <option value={p}>{p}</option>)}
                </select>
              </div>
              <p class="ck-err" data-err="provincia"></p>
            </div>
            <div class="ck-field">
              <label for="ck-pais">País</label>
              <input type="text" id="ck-pais" value="Argentina" disabled />
            </div>
          </div>
        </div>

      </div>

      <div class="ck-nav">
        <button type="button" class="ck-back" data-back="4">← Volver</button>
        <button type="button" class="ck-btn" data-next="5">
          Continuar
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </section>

    <!-- ══════════ PASO 3 · PLAN ══════════ -->
    <section class="ck-step" data-step="3" hidden>
      <div class="ck-card">
        <div class="ck-section-label">Tu pedido</div>

        <div class="ck-order">
          <div class="ck-order-head">
            <span class="ck-order-name">Registro de marca</span>
            <span class="ck-order-price">{formatARS(PRICING.honorarios)}</span>
          </div>
          <p class="ck-plan-sub">Honorarios · + arancel INPI</p>
          <ul class="ck-plan-feats">
            <li>Presentación de la solicitud ante el INPI</li>
            <li>Novedades del trámite por email</li>
            <li>Vigilancia de marca <s>{formatARS(PRICING.vigilanciaLista)}</s> <b>Gratis</b></li>
            <li id="ck-feat-garantia" class="ck-feat-off">Sin garantía de devolución: si el INPI deniega el registro, los honorarios no se devuelven</li>
          </ul>
        </div>

        <label class="ck-upsell">
          <input type="checkbox" id="ck-garantia" />
          <div class="ck-upsell-body">
            <div class="ck-upsell-head">
              <span class="ck-upsell-name">Sumá la Garantía de Devolución</span>
              <span class="ck-upsell-price">+{formatARS(PRICING.garantia)}</span>
            </div>
            <p class="ck-upsell-desc">
              Si el INPI deniega tu registro, te devolvemos los
              {formatARS(PRICING.honorarios)} de honorarios.
            </p>
          </div>
        </label>
      </div>

      <div class="ck-card ck-summary">
        <div class="ck-sum-row">
          <span>Honorarios — Registro de marca</span>
          <span>{formatARS(PRICING.honorarios)}</span>
        </div>
        <div class="ck-sum-row" id="ck-sum-garantia-row" hidden>
          <span>Garantía de Devolución</span>
          <span>{formatARS(PRICING.garantia)}</span>
        </div>
        <div class="ck-sum-row">
          <span>Arancel INPI (1 clase) <small>se paga al INPI · valor {PRICING.arancelVigencia}</small></span>
          <span>{formatARS(PRICING.arancelInpi)}</span>
        </div>
        <div class="ck-sum-row ck-sum-total">
          <span>Total</span>
          <span id="ck-sum-total">{formatARS(PRICING.honorarios + PRICING.arancelInpi)}</span>
        </div>
      </div>

      <p class="ck-disclaimer">
        El registro de una marca está sujeto a la resolución del INPI. Durante el trámite
        pueden surgir oposiciones de terceros u observaciones; te notificaremos y podrás
        decidir cómo continuar.
      </p>

      <div class="ck-nav">
        <button type="button" class="ck-back" data-back="2">← Volver</button>
        <button type="button" class="ck-btn" data-next="3">
          Continuar
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </section>

    <!-- ══════════ PASO 4 · PAGO (placeholder v1) ══════════ -->
    <section class="ck-step" data-step="4" hidden>
      <div class="ck-card">
        <div class="ck-section-label">Pago</div>

        <div class="ck-pay-summary">
          <div class="ck-pay-marca" id="ck-pay-marca">MARCA</div>
          <div class="ck-pay-detail"><span id="ck-pay-plan">Registro Simple</span> · Clase <span id="ck-pay-clase">–</span></div>
          <div class="ck-pay-total">Total: <b id="ck-pay-total">–</b></div>
        </div>

        <button type="button" class="ck-mp-btn" id="ck-mp-btn">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><ellipse cx="12" cy="12" rx="11" ry="8" stroke="currentColor" stroke-width="1.6"/><path d="M5 12c2-.8 3.4-2.4 4.6-2.4 1.3 0 1.8 1.2 2.9 1.2 1 0 1.7-.9 3-.9 1.5 0 2.4 1.3 3.5 2.1" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
          <span id="ck-mp-label">Pagar con Mercado Pago</span>
        </button>
        <p class="ck-err" data-err="pago" style="text-align:center; margin-top:0.6rem"></p>

        <p class="ck-help ck-pay-note">
          Vas a pagar en el sitio seguro de Mercado Pago y volvés acá para
          terminar tu solicitud.
        </p>
      </div>

      <div class="ck-nav">
        <button type="button" class="ck-back" data-back="3">← Volver</button>
        <!-- Solo demo/test: permite probar el flujo sin pagar. Quitar al launch. -->
        <button type="button" class="ck-btn ck-btn--ghost" data-next="4">
          Saltar pago (demo)
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </section>

    <!-- ══════════ PASO 6 · REVISIÓN Y FIRMA ══════════ -->
    <section class="ck-step" data-step="6" hidden>
      <div class="ck-card">
        <div class="ck-section-label">Revisá tu carta poder</div>
        <p class="ck-help" style="margin-bottom: 1rem">
          Este documento nos autoriza a presentar y gestionar tu solicitud ante el INPI.
          Revisá que todos los datos sean correctos.
        </p>
        <div class="ck-cp" id="ck-cp-preview"></div>
        <button type="button" class="ck-link-btn" id="ck-edit-datos">✎ Editar mis datos</button>
      </div>

      <div class="ck-card">
        <div class="ck-section-label">Tu firma</div>
        <p class="ck-help" style="margin-bottom: 0.75rem">
          Firmá en el recuadro con el dedo (celular) o con el mouse, como lo harías en papel.
        </p>
        <div class="ck-sig-box">
          <canvas id="ck-sig"></canvas>
          <span class="ck-sig-hint" id="ck-sig-hint">Firmá acá</span>
        </div>
        <div class="ck-sig-foot">
          <button type="button" class="ck-link-btn" id="ck-sig-clear">Borrar y firmar de nuevo</button>
        </div>

        <!-- TODO: crear /terminos y /privacidad y linkearlos acá antes del launch -->
        <label class="ck-terms">
          <input type="checkbox" id="ck-terms" />
          <span>Acepto los términos del servicio y la política de privacidad, y autorizo el uso de mi firma en la carta poder.</span>
        </label>
      </div>

      <div class="ck-nav">
        <button type="button" class="ck-back" data-back="5">← Volver</button>
        <button type="button" class="ck-btn" id="ck-submit" disabled>
          <span id="ck-submit-label">Confirmar y enviar solicitud</span>
          <svg id="ck-submit-spin" width="16" height="16" viewBox="0 0 16 16" fill="none" style="display:none"><circle cx="8" cy="8" r="6" stroke="rgba(255,255,255,.3)" stroke-width="2"/><path d="M8 2a6 6 0 0 1 6 6" stroke="white" stroke-width="2" stroke-linecap="round"/></svg>
        </button>
      </div>
    </section>

    <!-- ══════════ CONFIRMACIÓN ══════════ -->
    <section class="ck-step" data-step="done" hidden>
      <div class="ck-card ck-done">
        <svg width="52" height="52" viewBox="0 0 52 52" fill="none"><circle cx="26" cy="26" r="25" fill="#22c55e" fill-opacity=".12"/><path d="M16 26.5l7 7 13-14" stroke="#16a34a" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <h2>¡Listo! Recibimos tu solicitud.</h2>
        <p class="ck-done-ref">N° de referencia: <b id="ck-ref"></b></p>
        <p>Te enviamos una copia de tu carta poder firmada a <b id="ck-done-email"></b>.</p>
        <p>
          Presentaremos tu solicitud ante el INPI dentro de las próximas
          <b>48 horas hábiles</b> y te enviaremos todas las notificaciones del
          trámite por email.
        </p>
      </div>
    </section>

  </div>
</div>

</BaseLayout>

<script>
  import { NIZA_CLASSES } from '../lib/checkout/nizaClasses';
  import { PRICING, formatARS } from '../lib/checkout/constants';
  import { formatCuitInput, isValidCuit, cuitMatchesDni } from '../lib/checkout/cuit';
  import { cartaPoderHTML, type CartaPoderData } from '../lib/checkout/cartaPoder';

  const DRAFT_KEY = 'um-checkout-draft';
  const $ = (id: string) => document.getElementById(id) as HTMLElement;
  const input = (id: string) => document.getElementById(id) as HTMLInputElement;

  // Modo test: ningún campo es obligatorio (los formatos se validan solo si
  // hay valor). TODO: volver a false antes del launch.
  const FIELDS_OPTIONAL = true;

  // ── Estado ──────────────────────────────────────────────
  let clase: number | null = null;
  let garantia = false;
  let orderRef: string | null = null; // pedido creado al iniciar el pago MP

  const FIELD_IDS = [
    'ck-marca', 'ck-nombre', 'ck-dni', 'ck-cuit', 'ck-calle', 'ck-numero',
    'ck-piso', 'ck-depto', 'ck-localidad', 'ck-codpostal', 'ck-provincia',
    'ck-email', 'ck-whatsapp',
  ];

  function saveDraft() {
    const values: Record<string, string> = {};
    FIELD_IDS.forEach(id => { values[id] = input(id).value; });
    localStorage.setItem(DRAFT_KEY, JSON.stringify({ values, clase, garantia }));
  }

  function restoreDraft() {
    try {
      const raw = localStorage.getItem(DRAFT_KEY);
      if (!raw) return;
      const draft = JSON.parse(raw);
      FIELD_IDS.forEach(id => { if (draft.values?.[id]) input(id).value = draft.values[id]; });
      if (draft.clase) selectClase(draft.clase, false);
      if (typeof draft.garantia === 'boolean') {
        garantia = draft.garantia;
        input('ck-garantia').checked = garantia;
        updateSummary();
      }
    } catch { /* draft corrupto: ignorar */ }
  }

  // ── Navegación entre pasos ──────────────────────────────
  const TOTAL_STEPS = 6;
  const STEP_TITLES: Record<string, string> = {
    '1': 'Tu marca', '2': 'Contacto', '3': 'Tu pedido',
    '4': 'Pago', '5': 'Datos del titular', '6': 'Revisión y firma',
  };

  function goTo(step: string) {
    document.querySelectorAll<HTMLElement>('.ck-step').forEach(s => {
      s.hidden = s.dataset.step !== step;
    });
    if (step === 'done') {
      $('ck-progress').hidden = true;
    } else {
      const n = parseInt(step, 10);
      $('ck-step-label').textContent = `Paso ${n} de ${TOTAL_STEPS}`;
      $('ck-step-title').textContent = STEP_TITLES[step];
      $('ck-bar-fill').style.width = `${(n / TOTAL_STEPS) * 100}%`;
    }
    if (step === '4') updatePaySummary();
    if (step === '6') { renderPreview(); sizeCanvas(); }
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // ── Errores inline ──────────────────────────────────────
  function setErr(key: string, msg: string) {
    const el = document.querySelector<HTMLElement>(`[data-err="${key}"]`);
    if (el) { el.textContent = msg; el.style.display = msg ? 'block' : 'none'; }
  }
  function clearErrs(keys: string[]) { keys.forEach(k => setErr(k, '')); }

  // ── Validación por paso ─────────────────────────────────
  // Con FIELDS_OPTIONAL, los campos vacíos pasan; el formato se valida
  // solo cuando el usuario cargó algo.
  function validateStep1(): boolean {
    clearErrs(['marca', 'clase']);
    if (FIELDS_OPTIONAL) return true;
    let ok = true;
    if (input('ck-marca').value.trim().length < 2) {
      setErr('marca', 'Ingresá el nombre de tu marca.'); ok = false;
    }
    if (!clase) { setErr('clase', 'Seleccioná la clase de tu marca.'); ok = false; }
    return ok;
  }

  function validateContacto(): boolean {
    clearErrs(['email', 'whatsapp']);
    let ok = true;

    const email = input('ck-email').value.trim();
    if (email || !FIELDS_OPTIONAL) {
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { setErr('email', 'Ingresá un email válido.'); ok = false; }
    }

    const wa = input('ck-whatsapp').value.replace(/\D/g, '');
    if (wa || !FIELDS_OPTIONAL) {
      if (wa.length < 10) { setErr('whatsapp', 'Ingresá un número de WhatsApp válido (con código de área).'); ok = false; }
    }

    return ok;
  }

  function validateTitular(): boolean {
    const keys = ['nombre', 'dni', 'cuit', 'calle', 'numero', 'localidad', 'codpostal', 'provincia'];
    clearErrs(keys);
    let ok = true;
    const req = (id: string, key: string, msg: string) => {
      if (!FIELDS_OPTIONAL && !input(id).value.trim()) { setErr(key, msg); ok = false; }
    };
    req('ck-nombre', 'nombre', 'Ingresá tu nombre y apellido.');

    const dni = input('ck-dni').value.replace(/\D/g, '');
    if (dni || !FIELDS_OPTIONAL) {
      if (dni.length < 7 || dni.length > 8) { setErr('dni', 'Ingresá un DNI válido (7 u 8 dígitos).'); ok = false; }
    }

    const cuit = input('ck-cuit').value;
    if (cuit || !FIELDS_OPTIONAL) {
      if (!isValidCuit(cuit)) {
        setErr('cuit', 'El CUIT/CUIL no es válido. Revisalo.'); ok = false;
      } else if (dni && !cuitMatchesDni(cuit, dni)) {
        setErr('cuit', 'El CUIT/CUIL no coincide con el DNI ingresado.'); ok = false;
      }
    }

    req('ck-calle', 'calle', 'Ingresá la calle.');
    req('ck-numero', 'numero', 'Ingresá el número.');
    req('ck-localidad', 'localidad', 'Ingresá la localidad.');
    req('ck-codpostal', 'codpostal', 'Ingresá el código postal.');
    req('ck-provincia', 'provincia', 'Seleccioná la provincia.');

    return ok;
  }

  // ── Dropdown de clases ──────────────────────────────────
  const ddBtn = $('ck-clase-btn');
  const ddPanel = $('ck-clase-panel');
  const ddSearch = input('ck-clase-search');

  function normalize(s: string): string {
    return s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');
  }

  function toggleDd(open?: boolean) {
    const show = open ?? ddPanel.hidden;
    ddPanel.hidden = !show;
    ddBtn.setAttribute('aria-expanded', String(show));
    if (show) { ddSearch.value = ''; filterClases(''); ddSearch.focus(); }
  }

  function filterClases(q: string) {
    const nq = normalize(q);
    document.querySelectorAll<HTMLElement>('.ck-dd-opt').forEach(opt => {
      const text = normalize(opt.textContent || '');
      (opt.parentElement as HTMLElement).hidden = nq !== '' && !text.includes(nq);
    });
  }

  function selectClase(num: number, save = true) {
    clase = num;
    const c = NIZA_CLASSES.find(x => x.num === num);
    const label = $('ck-clase-label');
    label.textContent = c ? `Clase ${c.num} — ${c.nombre}` : `Clase ${num}`;
    label.classList.remove('ck-dd-placeholder');
    document.querySelectorAll<HTMLElement>('.ck-dd-opt').forEach(opt => {
      opt.classList.toggle('selected', parseInt(opt.dataset.num || '', 10) === num);
    });
    setErr('clase', '');
    if (save) saveDraft();
  }

  ddBtn.addEventListener('click', () => toggleDd());
  ddSearch.addEventListener('input', () => filterClases(ddSearch.value));
  document.querySelectorAll<HTMLElement>('.ck-dd-opt').forEach(opt => {
    opt.addEventListener('click', () => { selectClase(parseInt(opt.dataset.num || '', 10)); toggleDd(false); });
  });
  document.addEventListener('click', (e) => {
    if (!$('ck-clase-dd').contains(e.target as Node)) toggleDd(false);
  });

  // ── Garantía (upsell) y resumen ─────────────────────────
  const FEAT_GARANTIA = {
    off: 'Sin garantía de devolución: si el INPI deniega el registro, los honorarios no se devuelven',
    on: 'Garantía de Devolución incluida: si el INPI deniega el registro, te devolvemos los honorarios',
  };

  function total(): number {
    return PRICING.honorarios + (garantia ? PRICING.garantia : 0) + PRICING.arancelInpi;
  }

  function updateSummary() {
    const feat = $('ck-feat-garantia');
    feat.textContent = garantia ? FEAT_GARANTIA.on : FEAT_GARANTIA.off;
    feat.classList.toggle('ck-feat-off', !garantia);
    feat.classList.toggle('ck-feat-on', garantia);
    $('ck-sum-garantia-row').hidden = !garantia;
    $('ck-sum-total').textContent = formatARS(total());
  }

  input('ck-garantia').addEventListener('change', () => {
    garantia = input('ck-garantia').checked;
    updateSummary();
    saveDraft();
  });

  function updatePaySummary() {
    $('ck-pay-marca').textContent = input('ck-marca').value.trim().toUpperCase() || 'TU MARCA';
    $('ck-pay-plan').textContent = 'Registro de marca' + (garantia ? ' + Garantía de Devolución' : '');
    $('ck-pay-clase').textContent = clase ? String(clase) : '–';
    $('ck-pay-total').textContent = formatARS(total());
  }

  // ── Mercado Pago ────────────────────────────────────────
  const mpBtn = document.getElementById('ck-mp-btn') as HTMLButtonElement;

  mpBtn.addEventListener('click', async () => {
    setErr('pago', '');
    mpBtn.disabled = true;
    $('ck-mp-label').textContent = 'Redirigiendo a Mercado Pago…';
    try {
      const res = await fetch('/api/checkout/order', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          marca: { nombre: input('ck-marca').value.trim(), tipo: 'Denominativa' },
          clase,
          contacto: {
            email: input('ck-email').value.trim(),
            whatsapp: input('ck-whatsapp').value.trim(),
          },
          garantia,
        }),
      });
      const data = await res.json();
      if (!res.ok || !data.init_point) throw new Error(data.error || 'sin init_point');
      saveDraft(); // por si vuelve en el mismo navegador
      window.location.href = data.init_point;
    } catch (e) {
      console.error('[um-checkout] error iniciando pago:', e);
      setErr('pago', 'No pudimos iniciar el pago. Probá de nuevo en unos segundos.');
      mpBtn.disabled = false;
      $('ck-mp-label').textContent = 'Pagar con Mercado Pago';
    }
  });

  function showPayBanner(status: string) {
    const banner = $('ck-pay-banner');
    const kind =
      status === 'paid' ? 'ok' :
      status === 'rejected' ? 'err' : 'warn';
    const msg =
      status === 'paid'
        ? '<b>✓ Pago aprobado.</b> Recibimos tu pago. Completá los datos para terminar tu solicitud.'
        : status === 'rejected'
          ? '<b>El pago fue rechazado.</b> Podés <button type="button" class="ck-banner-link" id="ck-retry-pay">reintentar el pago</button> o continuar y lo coordinamos después.'
          : '<b>Tu pago está pendiente de confirmación.</b> Podés completar tus datos mientras tanto; te avisamos por email cuando se acredite.';
    banner.className = `ck-banner ck-banner--${kind}`;
    banner.innerHTML = msg;
    banner.hidden = false;
    document.getElementById('ck-retry-pay')?.addEventListener('click', () => goTo('4'));
  }

  async function resumeOrder(ref: string) {
    try {
      const res = await fetch(`/api/checkout/order/${encodeURIComponent(ref)}`);
      if (!res.ok) return false;
      const o = await res.json();
      orderRef = o.ref;
      const p = o.payload || {};
      if (p.marca?.nombre) input('ck-marca').value = p.marca.nombre;
      if (p.clase) selectClase(p.clase, false);
      if (p.contacto?.email) input('ck-email').value = p.contacto.email;
      if (p.contacto?.whatsapp) input('ck-whatsapp').value = p.contacto.whatsapp;
      garantia = !!p.garantia;
      input('ck-garantia').checked = garantia;
      updateSummary();
      showPayBanner(o.status);
      goTo('5');
      return true;
    } catch {
      return false;
    }
  }

  // ── Carta poder: preview ────────────────────────────────
  function cpData(): CartaPoderData {
    const now = new Date();
    return {
      nombreApellido: input('ck-nombre').value.trim(),
      dni: input('ck-dni').value.replace(/\D/g, ''),
      cuit: input('ck-cuit').value.trim(),
      calle: input('ck-calle').value.trim(),
      numero: input('ck-numero').value.trim(),
      piso: input('ck-piso').value.trim() || undefined,
      depto: input('ck-depto').value.trim() || undefined,
      codigoPostal: input('ck-codpostal').value.trim(),
      localidad: input('ck-localidad').value.trim(),
      provincia: input('ck-provincia').value,
      marca: input('ck-marca').value,
      clases: clase ? [clase] : [],
      fecha: { dia: now.getDate(), mes: now.getMonth(), anio: now.getFullYear() },
    };
  }

  function renderPreview() {
    $('ck-cp-preview').innerHTML = cartaPoderHTML(cpData());
  }

  $('ck-edit-datos').addEventListener('click', () => goTo('5'));

  // ── Firma (canvas) ──────────────────────────────────────
  const canvas = document.getElementById('ck-sig') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const SIG_H = 180;
  let strokes: { x: number; y: number }[][] = [];
  let drawing = false;

  function sizeCanvas() {
    const dpr = window.devicePixelRatio || 1;
    const w = canvas.parentElement!.getBoundingClientRect().width;
    if (w === 0) return; // paso oculto
    canvas.width = w * dpr;
    canvas.height = SIG_H * dpr;
    canvas.style.width = `${w}px`;
    canvas.style.height = `${SIG_H}px`;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    redraw();
  }

  function redraw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.strokeStyle = '#0f172a';
    ctx.lineWidth = 2;
    ctx.lineJoin = 'round';
    ctx.lineCap = 'round';
    strokes.forEach(stroke => {
      ctx.beginPath();
      stroke.forEach((p, i) => (i === 0 ? ctx.moveTo(p.x, p.y) : ctx.lineTo(p.x, p.y)));
      ctx.stroke();
    });
  }

  function sigPos(e: PointerEvent) {
    const r = canvas.getBoundingClientRect();
    return { x: e.clientX - r.left, y: e.clientY - r.top };
  }

  canvas.addEventListener('pointerdown', (e) => {
    e.preventDefault();
    canvas.setPointerCapture(e.pointerId);
    drawing = true;
    strokes.push([sigPos(e)]);
    $('ck-sig-hint').hidden = true;
  });
  canvas.addEventListener('pointermove', (e) => {
    if (!drawing) return;
    const stroke = strokes[strokes.length - 1];
    stroke.push(sigPos(e));
    const [a, b] = [stroke[stroke.length - 2], stroke[stroke.length - 1]];
    ctx.strokeStyle = '#0f172a';
    ctx.lineWidth = 2;
    ctx.lineJoin = 'round';
    ctx.lineCap = 'round';
    ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y); ctx.stroke();
  });
  const endStroke = () => { drawing = false; updateSubmitState(); };
  canvas.addEventListener('pointerup', endStroke);
  canvas.addEventListener('pointercancel', endStroke);
  window.addEventListener('resize', sizeCanvas);

  $('ck-sig-clear').addEventListener('click', () => {
    strokes = [];
    redraw();
    $('ck-sig-hint').hidden = false;
    updateSubmitState();
  });

  // ── Envío ───────────────────────────────────────────────
  const submitBtn = document.getElementById('ck-submit') as HTMLButtonElement;
  const termsCheck = input('ck-terms');

  function updateSubmitState() {
    submitBtn.disabled = strokes.length === 0 || !termsCheck.checked;
  }
  termsCheck.addEventListener('change', updateSubmitState);

  submitBtn.addEventListener('click', async () => {
    submitBtn.disabled = true;
    $('ck-submit-label').textContent = 'Enviando…';
    $('ck-submit-spin').style.display = '';

    const payload = {
      marca: { nombre: input('ck-marca').value.trim(), tipo: 'Denominativa' },
      clase,
      titular: {
        tipoPersona: 'Humana',
        nombre: input('ck-nombre').value.trim(),
        dni: input('ck-dni').value.replace(/\D/g, ''),
        cuit: input('ck-cuit').value.trim(),
        domicilio: {
          pais: 'Argentina',
          calle: input('ck-calle').value.trim(),
          numero: input('ck-numero').value.trim(),
          piso: input('ck-piso').value.trim(),
          depto: input('ck-depto').value.trim(),
          localidad: input('ck-localidad').value.trim(),
          codigoPostal: input('ck-codpostal').value.trim(),
          provincia: input('ck-provincia').value,
        },
      },
      contacto: {
        email: input('ck-email').value.trim(),
        whatsapp: input('ck-whatsapp').value.trim(),
      },
      garantia,
      pricing: {
        honorarios: PRICING.honorarios,
        garantia: garantia ? PRICING.garantia : 0,
        arancelInpi: PRICING.arancelInpi,
        total: total(),
      },
      payment: { status: 'skipped', provider: null },
      firma: canvas.toDataURL('image/png'),
    };

    // Con pedido MP: adjuntar titular + firma al pedido en D1.
    // Sin pedido (ruta "Saltar pago"): envío simulado, solo para testear la UX.
    // TODO(fase emails): PDF de la carta poder + emails (spec §7).
    let ref: string;
    if (orderRef) {
      try {
        const res = await fetch(`/api/checkout/order/${encodeURIComponent(orderRef)}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (!res.ok) throw new Error(String(res.status));
      } catch (e) {
        console.error('[um-checkout] error guardando la solicitud:', e);
        alert('No pudimos guardar tu solicitud. Probá de nuevo.');
        submitBtn.disabled = false;
        $('ck-submit-label').textContent = 'Confirmar y enviar solicitud';
        $('ck-submit-spin').style.display = 'none';
        return;
      }
      ref = orderRef;
    } else {
      console.info('[um-checkout] payload (demo, sin pedido MP):', payload);
      await new Promise(r => setTimeout(r, 900));
      const now = new Date();
      const ymd = `${now.getFullYear()}${String(now.getMonth() + 1).padStart(2, '0')}${String(now.getDate()).padStart(2, '0')}`;
      ref = `UM-${ymd}-${String(Math.floor(Math.random() * 10000)).padStart(4, '0')}`;
    }

    $('ck-ref').textContent = ref;
    $('ck-done-email').textContent = payload.contacto.email;

    localStorage.removeItem(DRAFT_KEY);
    goTo('done');
  });

  // ── Inputs: formato y draft ─────────────────────────────
  input('ck-cuit').addEventListener('input', (e) => {
    const el = e.target as HTMLInputElement;
    el.value = formatCuitInput(el.value);
  });
  input('ck-dni').addEventListener('input', (e) => {
    const el = e.target as HTMLInputElement;
    el.value = el.value.replace(/\D/g, '').slice(0, 8);
  });
  FIELD_IDS.forEach(id => input(id).addEventListener('input', () => {
    setErr(id.replace('ck-', ''), ''); // al corregir, el error desaparece
    saveDraft();
  }));

  // ── Botones Continuar / Volver ──────────────────────────
  const VALIDATORS: Record<string, () => boolean> = {
    '1': validateStep1, '2': validateContacto, '5': validateTitular,
  };

  document.querySelectorAll<HTMLElement>('[data-next]').forEach(btn => {
    btn.addEventListener('click', () => {
      const from = btn.dataset.next!;
      const validator = VALIDATORS[from];
      if (validator && !validator()) return;
      goTo(String(parseInt(from, 10) + 1));
    });
  });
  document.querySelectorAll<HTMLElement>('[data-back]').forEach(btn => {
    btn.addEventListener('click', () => goTo(btn.dataset.back!));
  });

  // ── Bootstrap: volver de Mercado Pago (?order=REF) o draft local ─────
  const urlOrderRef = new URLSearchParams(window.location.search).get('order');
  if (urlOrderRef) {
    resumeOrder(urlOrderRef).then(ok => { if (!ok) restoreDraft(); });
  } else {
    restoreDraft();
  }
</script>

