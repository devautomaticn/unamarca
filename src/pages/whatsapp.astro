        padding: 40px 32px;
        max-width: 400px;
        width: 100%;
        text-align: center;
      }

      .logo {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 28px;
        font-weight: 700;
        font-size: 16px;
        color: #fff;
        text-decoration: none;
      }

      .logo svg { flex-shrink: 0; }

      .icon {
        width: 64px;
        height: 64px;
        background: rgba(34,197,94,0.12);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
      }

      h1 {
        font-size: 22px;
        font-weight: 700;
        color: #fff;
        line-height: 1.3;
        margin-bottom: 10px;
      }

      p {
        font-size: 15px;
        color: #94A3B8;
        line-height: 1.6;
        margin-bottom: 28px;
      }

      .cta {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        background: #22C55E;
        color: #000;
        font-weight: 700;
        font-size: 16px;
        text-decoration: none;
        padding: 16px 28px;
        border-radius: 100px;
        transition: background 0.15s, transform 0.1s;
      }

      .cta:active { transform: scale(0.97); }
      .cta:hover { background: #16A34A; color: #fff; }

      .reassurance {
        margin-top: 20px;
        font-size: 12px;
        color: #64748B;
      }

      .checks {
        text-align: left;
        background: rgba(255,255,255,0.03);
        border-radius: 12px;
        padding: 16px 20px;
        margin-bottom: 24px;
        display: flex;
        flex-direction: column;
        gap: 8px;
      }

      .check {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 14px;
        color: #CBD5E1;
      }

      .check-dot {
        width: 18px;
        height: 18px;
        border-radius: 50%;
        background: rgba(34,197,94,0.15);
        color: #22C55E;
        font-size: 10px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }
