---
import BaseLayout from '../layouts/BaseLayout.astro';

const SITE_URL = 'https://unamarca.com.ar';

const nizaClasses = [
  { num: 1,  desc: 'Productos químicos industriales y científicos' },
  { num: 2,  desc: 'Pinturas, barnices, lacas, preservativos' },
  { num: 3,  desc: 'Cosméticos, perfumería, limpieza' },
  { num: 4,  desc: 'Aceites y grasas industriales, combustibles' },
  { num: 5,  desc: 'Productos farmacéuticos y veterinarios' },
  { num: 6,  desc: 'Metales comunes y sus aleaciones' },
  { num: 7,  desc: 'Máquinas y máquinas herramientas' },
  { num: 8,  desc: 'Herramientas e instrumentos de mano' },
  { num: 9,  desc: 'Aparatos científicos, ópticos, informáticos, electrónicos' },
  { num: 10, desc: 'Aparatos médicos y quirúrgicos' },
  { num: 11, desc: 'Aparatos de alumbrado, calefacción, refrigeración' },
  { num: 12, desc: 'Vehículos y medios de transporte' },
  { num: 13, desc: 'Armas de fuego, municiones, explosivos' },
  { num: 14, desc: 'Joyería, relojería, metales preciosos' },
  { num: 15, desc: 'Instrumentos musicales' },
  { num: 16, desc: 'Papel, cartón, artículos de imprenta' },
  { num: 17, desc: 'Caucho, goma, plásticos semielaborados' },
  { num: 18, desc: 'Cuero, artículos de viaje, bolsos' },
  { num: 19, desc: 'Materiales de construcción no metálicos' },
  { num: 20, desc: 'Muebles, espejos, marcos, madera' },
  { num: 21, desc: 'Utensilios del hogar, vidrio, porcelana' },
  { num: 22, desc: 'Cuerdas, redes, tiendas, telas técnicas' },
  { num: 23, desc: 'Hilos y fibras textiles industriales' },
  { num: 24, desc: 'Tejidos y sustitutos; ropa de hogar' },
  { num: 25, desc: 'Prendas de vestir, calzado, sombrerería' },
  { num: 26, desc: 'Encajes, bordados, botones, adornos textiles' },
  { num: 27, desc: 'Alfombras, revestimientos de suelos' },
  { num: 28, desc: 'Juegos, juguetes, artículos deportivos' },
  { num: 29, desc: 'Carne, pescado, aves, conservas, lácteos' },
  { num: 30, desc: 'Café, té, panadería, repostería, condimentos' },
  { num: 31, desc: 'Productos agrícolas, hortícolas, animales vivos' },
  { num: 32, desc: 'Cervezas, aguas, bebidas sin alcohol' },
  { num: 33, desc: 'Bebidas alcohólicas (excepto cervezas)' },
  { num: 34, desc: 'Tabaco, cigarrillos, artículos para fumadores' },
  { num: 35, desc: 'Publicidad, gestión comercial, oficina' },
  { num: 36, desc: 'Seguros, finanzas, inmobiliaria' },
  { num: 37, desc: 'Construcción, reparación, instalación' },
  { num: 38, desc: 'Telecomunicaciones' },
  { num: 39, desc: 'Transporte, logística, almacenamiento' },
  { num: 40, desc: 'Tratamiento de materiales, reciclaje' },
  { num: 41, desc: 'Educación, entretenimiento, deporte, cultura' },
  { num: 42, desc: 'Servicios científicos, tecnológicos, informáticos' },
  { num: 43, desc: 'Restauración, alojamiento temporal' },
  { num: 44, desc: 'Servicios médicos, veterinarios, de belleza' },
  { num: 45, desc: 'Servicios jurídicos, de seguridad, personales' },
];

const provinces = [
  'Buenos Aires', 'Catamarca', 'Chaco', 'Chubut',
  'Ciudad Autónoma de Buenos Aires', 'Córdoba', 'Corrientes',
  'Entre Ríos', 'Formosa', 'Jujuy', 'La Pampa', 'La Rioja',
  'Mendoza', 'Misiones', 'Neuquén', 'Río Negro', 'Salta',
  'San Juan', 'San Luis', 'Santa Cruz', 'Santa Fe',
  'Santiago del Estero', 'Tierra del Fuego', 'Tucumán',
];
---

<BaseLayout
  title="Formulario de Registro de Marca | UnaMarca"
  description="Completá el formulario para iniciar el registro de tu marca ante el INPI Argentina."
  canonicalURL={`${SITE_URL}/formularioregistro`}
>

  <div class="form-page">
    <div class="form-container">

      <header class="form-header">
        <div class="form-header-badge">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M8 1.5L2.5 4v4c0 3.2 2.4 5.8 5.5 6.5 3.1-.7 5.5-3.3 5.5-6.5V4L8 1.5z" fill="currentColor"/>
          </svg>
          INPI Argentina
        </div>
        <h1>Registro de Marca</h1>
        <p>Completá los datos para iniciar el trámite. Nos pondremos en contacto a la brevedad.</p>
      </header>

      <!-- SUCCESS -->
      <div id="form-success" class="toast toast--success" hidden>
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <circle cx="10" cy="10" r="9" fill="#22C55E" opacity="0.15"/>
          <path d="M6 10.5l2.8 2.8 5.2-5.6" stroke="#16a34a" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <div>
          <strong>¡Formulario enviado!</strong>
          <span>Recibimos tu información y te contactamos a la brevedad.</span>
        </div>
      </div>

      <!-- ERROR -->
      <div id="form-error" class="toast toast--error" hidden>
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <circle cx="10" cy="10" r="9" fill="#EF4444" opacity="0.15"/>
          <path d="M10 6.5v4M10 13h.01" stroke="#dc2626" stroke-width="1.75" stroke-linecap="round"/>
        </svg>
        <div>
          <strong>No se pudo enviar el formulario.</strong>
          <span>Intentá de nuevo o escribinos por WhatsApp.</span>
        </div>
      </div>

      <form id="registro-form" novalidate>

        <!-- ══════════════════════════════
             MARCA
        ══════════════════════════════ -->
        <div class="card">
          <div class="card-header">
            <h2>Marca</h2>
          </div>
          <div class="card-body">
            <div class="grid grid-2">
              <div class="field">
                <label for="marca-nombre">Nombre de la Marca <span class="req">*</span></label>
                <input type="text" id="marca-nombre" name="marca-nombre"
                  placeholder="De Casa Florentino" required autocomplete="off" />
              </div>
              <div class="field">
                <label for="marca-tipo">Tipo de Marca <span class="req">*</span></label>
                <div class="select-wrap">
                  <select id="marca-tipo" name="marca-tipo" required>
                    <option value="Denominativa" selected>Denominativa</option>
                    <option value="Mixta">Mixta</option>
                    <option value="Figurativa">Figurativa</option>
                    <option value="Otro">Otro</option>
                  </select>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- ══════════════════════════════
             TITULARES
        ══════════════════════════════ -->
        <div class="card">
          <div class="card-header">
            <h2>Titulares</h2>
          </div>

          <div id="titulares-container"></div>

          <div class="card-footer">
            <button type="button" id="add-titular-btn" class="btn-ghost">
              <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
                <path d="M7.5 2v11M2 7.5h11" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
              </svg>
              Agregar titular
            </button>
            <span id="pct-indicator" class="pct-indicator" aria-live="polite"></span>
          </div>
        </div>

        <!-- ══════════════════════════════
             CLASES
        ══════════════════════════════ -->
        <div class="card">
          <div class="card-header">
            <h2>Clases Niza</h2>
            <p class="card-subtitle">Opcional — marcá las clases en las que querés registrar la marca</p>
          </div>
          <div class="card-body">
            <div class="clases-grid">
              {nizaClasses.map(c => (
                <label class="clase-pill">
                  <input type="checkbox" name="clases" value={c.num} />
                  <span class="clase-pill-num">{String(c.num).padStart(2, '0')}</span>
                  <span class="clase-pill-desc">{c.desc}</span>
                </label>
              ))}
            </div>
          </div>
        </div>

        <!-- SUBMIT -->
        <div class="submit-row">
          <button type="submit" id="submit-btn" class="btn-submit">
            <span id="submit-label">Enviar formulario</span>
            <svg id="submit-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <svg id="submit-spinner" class="spinner" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" hidden>
              <circle cx="8" cy="8" r="6" stroke="rgba(255,255,255,0.3)" stroke-width="2"/>
              <path d="M8 2a6 6 0 0 1 6 6" stroke="white" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </button>
        </div>

      </form>
    </div>
  </div>

</BaseLayout>

<script define:vars={{ provinces }}>
  let titularCount = 0;

  const provinceOptions = provinces
    .map(p => `<option value="${p}">${p}</option>`)
    .join('');

  // ── Build titular HTML ─────────────────────────────
  function buildTitularHTML(idx) {
    return `
    <div class="titular" id="titular-${idx}" data-idx="${idx}">
      <div class="titular-head">
        <span class="titular-label">Titular <span class="titular-num">${idx + 1}</span></span>
        <button type="button" class="btn-remove" data-target="${idx}" aria-label="Eliminar titular">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M2 2l10 10M12 2L2 12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
          </svg>
        </button>
      </div>

      <div class="titular-body">
        <div class="grid grid-2">
          <div class="field">
            <label>Tipo de Persona <span class="req">*</span></label>
            <div class="select-wrap">
              <select name="tipo-persona-${idx}" class="tipo-persona" data-idx="${idx}" required>
                <option value="">Seleccionar…</option>
                <option value="Humana">Humana</option>
                <option value="Juridica">Jurídica</option>
              </select>
            </div>
          </div>
          <div class="field">
            <label class="nombre-label-${idx}">Nombre <span class="req">*</span></label>
            <input type="text" name="nombre-${idx}" placeholder="Nombre completo" required autocomplete="off" />
          </div>
        </div>

        <div class="grid grid-2 cond-humana-${idx}" style="display:none">
          <div class="field">
            <label>Género <span class="req">*</span></label>
            <div class="select-wrap">
              <select name="genero-${idx}">
                <option value="">Seleccionar…</option>
                <option value="Masculino">Masculino</option>
                <option value="Femenino">Femenino</option>
                <option value="Otro">Otro</option>
              </select>
            </div>
          </div>
          <div class="field">
            <label>Estado Civil <span class="req">*</span></label>
            <div class="select-wrap">
              <select name="estado-civil-${idx}" class="estado-civil" data-idx="${idx}">
                <option value="">Seleccionar…</option>
                <option value="Soltero/a">Soltero/a</option>
                <option value="Casado/a">Casado/a</option>
                <option value="Divorciado/a">Divorciado/a</option>
                <option value="Viudo/a">Viudo/a</option>
              </select>
            </div>
          </div>
        </div>

        <div class="cond-conyuge-${idx}" style="display:none">
          <div class="field">
            <label>Nombre del Cónyuge <span class="req">*</span></label>
            <input type="text" name="nombre-conyuge-${idx}" placeholder="Nombre completo del cónyuge" autocomplete="off" />
          </div>
        </div>

        <div class="grid grid-3">
          <div class="field field--span2">
            <label>CUIT / CUIL <span class="req">*</span></label>
            <input type="text" name="cuit-${idx}" placeholder="20-12345678-9" required autocomplete="off" />
          </div>
          <div class="field">
            <label>Porcentaje % <span class="req">*</span></label>
            <input type="number" name="porcentaje-${idx}" class="pct-input" min="1" max="100" step="1" placeholder="100" required />
          </div>
        </div>

        <div class="field">
          <label>Correo Electrónico <span class="req">*</span></label>
          <input type="email" name="email-${idx}" placeholder="correo@ejemplo.com" required autocomplete="email" />
        </div>

        <div class="domicilio">
          <p class="domicilio-heading">Domicilio Real</p>

          <div class="grid grid-2">
            <div class="field">
              <label>País <span class="req">*</span></label>
              <input type="text" name="pais-${idx}" value="Argentina" required autocomplete="off" />
            </div>
            <div class="field">
              <label>Provincia <span class="req">*</span></label>
              <div class="select-wrap">
                <select name="provincia-${idx}" required>
                  <option value="">Seleccionar…</option>
                  ${provinceOptions}
                </select>
              </div>
            </div>
          </div>

          <div class="grid grid-2">
            <div class="field">
              <label>Localidad <span class="req">*</span></label>
              <input type="text" name="localidad-${idx}" placeholder="Localidad" required autocomplete="off" />
            </div>
            <div class="field">
              <label>Código Postal <span class="req">*</span></label>
              <input type="text" name="codigo-postal-${idx}" placeholder="C1406" required autocomplete="off" />
            </div>
          </div>

          <div class="grid grid-2">
            <div class="field">
              <label>Calle <span class="req">*</span></label>
              <input type="text" name="calle-${idx}" placeholder="Av. Corrientes" required autocomplete="off" />
            </div>
            <div class="field">
              <label>Número <span class="req">*</span></label>
              <input type="text" name="numero-${idx}" placeholder="1234" required autocomplete="off" />
            </div>
          </div>

          <div class="grid grid-2">
            <div class="field">
              <label>Piso</label>
              <input type="text" name="piso-${idx}" placeholder="3" autocomplete="off" />
            </div>
            <div class="field">
              <label>Depto</label>
              <input type="text" name="depto-${idx}" placeholder="A" autocomplete="off" />
            </div>
          </div>
        </div>
      </div>
    </div>
    `;
  }

  // ── Add / remove ───────────────────────────────────
  function addTitular() {
    const container = document.getElementById('titulares-container');
    const idx = titularCount++;
    const div = document.createElement('div');
    div.innerHTML = buildTitularHTML(idx);
    container.appendChild(div.firstElementChild);
    attachListeners(idx);
    syncUI();
  }

  function removeTitular(idx) {
    document.getElementById(`titular-${idx}`)?.remove();
    syncUI();
  }

  function attachListeners(idx) {
    document.querySelector(`.btn-remove[data-target="${idx}"]`)
      ?.addEventListener('click', () => removeTitular(idx));

    document.querySelector(`select[name="tipo-persona-${idx}"]`)
      ?.addEventListener('change', () => { syncHumana(idx); syncLabel(idx); });

    document.querySelector(`select[name="estado-civil-${idx}"]`)
      ?.addEventListener('change', () => syncConyuge(idx));

    document.querySelector(`input[name="porcentaje-${idx}"]`)
      ?.addEventListener('input', syncPct);
  }

  function syncHumana(idx) {
    const tp = document.querySelector(`select[name="tipo-persona-${idx}"]`)?.value;
    const isHumana = tp === 'Humana';
    document.querySelectorAll(`.cond-humana-${idx}`).forEach(el => {
      el.style.display = isHumana ? '' : 'none';
      el.querySelectorAll('select,input').forEach(f =>
        isHumana ? f.setAttribute('required','') : f.removeAttribute('required')
      );
    });
    if (!isHumana) {
      const row = document.querySelector(`.cond-conyuge-${idx}`);
      if (row) row.style.display = 'none';
      document.querySelector(`input[name="nombre-conyuge-${idx}"]`)?.removeAttribute('required');
    }
  }

  function syncLabel(idx) {
    const tp = document.querySelector(`select[name="tipo-persona-${idx}"]`)?.value;
    const label = document.querySelector(`.nombre-label-${idx}`);
    if (!label) return;
    const text = tp === 'Juridica' ? 'Razón Social' : 'Nombre';
    label.firstChild.textContent = text + ' ';
  }

  function syncConyuge(idx) {
    const val = document.querySelector(`select[name="estado-civil-${idx}"]`)?.value;
    const row = document.querySelector(`.cond-conyuge-${idx}`);
    const inp = document.querySelector(`input[name="nombre-conyuge-${idx}"]`);
    if (!row) return;
    const show = val === 'Casado/a';
    row.style.display = show ? '' : 'none';
    show ? inp?.setAttribute('required','') : inp?.removeAttribute('required');
  }

  function syncPct() {
    const inputs = document.querySelectorAll('.pct-input');
    const ind = document.getElementById('pct-indicator');
    if (!ind || !inputs.length) return;
    let total = 0;
    inputs.forEach(i => { const v = parseFloat(i.value); if (!isNaN(v)) total += v; });
    const ok = Math.abs(total - 100) < 0.01;
    ind.textContent = `${total}%${ok ? ' ✓' : ' — debe sumar 100%'}`;
    ind.className = `pct-indicator ${ok ? 'pct-ok' : 'pct-warn'}`;
  }

  function syncUI() {
    const blocks = document.querySelectorAll('.titular');
    blocks.forEach((b, i) => {
      const n = b.querySelector('.titular-num');
      if (n) n.textContent = String(i + 1);
      const btn = b.querySelector('.btn-remove');
      if (btn) btn.style.opacity = blocks.length > 1 ? '1' : '0';
    });
    syncPct();
  }

  // ── Collect data ───────────────────────────────────
  function collect() {
    const fd = new FormData(document.getElementById('registro-form'));
    const marca = { nombre: fd.get('marca-nombre'), tipo: fd.get('marca-tipo') };

    const titulares = Array.from(document.querySelectorAll('.titular')).map(block => {
      const i = block.dataset.idx;
      const tipoPersona = fd.get(`tipo-persona-${i}`);
      const estadoCivil = fd.get(`estado-civil-${i}`);
      const t = {
        tipoPersona,
        nombre: fd.get(`nombre-${i}`),
        cuit: fd.get(`cuit-${i}`),
        porcentaje: parseFloat(fd.get(`porcentaje-${i}`) || '0'),
        email: fd.get(`email-${i}`),
        domicilio: {
          pais: fd.get(`pais-${i}`),
          provincia: fd.get(`provincia-${i}`),
          localidad: fd.get(`localidad-${i}`),
          codigoPostal: fd.get(`codigo-postal-${i}`),
          calle: fd.get(`calle-${i}`),
          numero: fd.get(`numero-${i}`),
          piso: fd.get(`piso-${i}`) || '',
          depto: fd.get(`depto-${i}`) || '',
        },
      };
      if (tipoPersona === 'Humana') {
        t.genero = fd.get(`genero-${i}`);
        t.estadoCivil = estadoCivil;
        if (estadoCivil === 'Casado/a') t.nombreConyuge = fd.get(`nombre-conyuge-${i}`);
      }
      return t;
    });

    const clases = Array.from(
      document.querySelectorAll('input[name="clases"]:checked')
    ).map(cb => parseInt(cb.value));

    return { marca, titulares, clases };
  }

  // ── Validate ───────────────────────────────────────
  function validate() {
    const form = document.getElementById('registro-form');
    if (!form.checkValidity()) { form.reportValidity(); return false; }
    const inputs = document.querySelectorAll('.pct-input');
    let total = 0;
    inputs.forEach(i => { const v = parseFloat(i.value); if (!isNaN(v)) total += v; });
    if (Math.abs(total - 100) > 0.01) {
      alert(`El porcentaje total debe sumar 100%. Actualmente suma ${total}%.`);
      return false;
    }
    return true;
  }

  // ── Submit ─────────────────────────────────────────
  async function handleSubmit(e) {
    e.preventDefault();
    if (!validate()) return;

    const btn = document.getElementById('submit-btn');
    const label = document.getElementById('submit-label');
    const icon = document.getElementById('submit-icon');
    const spinner = document.getElementById('submit-spinner');

    btn.disabled = true;
    label.textContent = 'Enviando';
    icon.hidden = true;
    spinner.hidden = false;

    try {
      const res = await fetch('/api/submit-form', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(collect()),
      });
      const json = await res.json();
      if (!json.success) throw new Error();
      document.getElementById('registro-form').style.display = 'none';
      const success = document.getElementById('form-success');
      success.hidden = false;
      success.scrollIntoView({ behavior: 'smooth', block: 'center' });
    } catch {
      const err = document.getElementById('form-error');
      err.hidden = false;
      err.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      btn.disabled = false;
      label.textContent = 'Enviar formulario';
      icon.hidden = false;
      spinner.hidden = true;
    }
  }

  document.getElementById('add-titular-btn').addEventListener('click', addTitular);
  document.getElementById('registro-form').addEventListener('submit', handleSubmit);
  addTitular(); // start with one
</script>

<style>
  /* ── Fix: hidden attribute must win ── */
  [hidden] { display: none !important; }

  /* ── Page shell ── */
  .form-page {
    min-height: 100vh;
    background: #f1f5f9;
    padding: 4rem 1.25rem 6rem;
  }

  .form-container {
    max-width: 680px;
    margin: 0 auto;
  }

  /* ── Header ── */
  .form-header {
    margin-bottom: 2.5rem;
  }

  .form-header-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    background: var(--c-blue-light);
    color: var(--c-blue);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.3rem 0.75rem;
    border-radius: 100px;
    margin-bottom: 1rem;
  }

  .form-header h1 {
    font-size: clamp(1.6rem, 4vw, 2.25rem);
    font-weight: 800;
    color: var(--c-navy);
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
  }

  .form-header p {
    color: var(--c-text-muted);
    font-size: 0.9375rem;
    margin: 0;
  }

  /* ── Toast notifications ── */
  .toast {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border-radius: 12px;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .toast svg { flex-shrink: 0; margin-top: 1px; }
  .toast strong { display: block; font-weight: 600; }
