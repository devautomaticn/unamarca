---
import BaseLayout from '../layouts/BaseLayout.astro';

const SITE_URL = 'https://unamarca.com.ar';

const nizaClasses = [
  { num: 1,  desc: 'Productos químicos industriales y científicos' },
  { num: 2,  desc: 'Pinturas, barnices, lacas, preservativos' },
  { num: 3,  desc: 'Cosméticos, perfumería, limpieza' },
  { num: 4,  desc: 'Aceites y grasas industriales, combustibles' },
  { num: 5,  desc: 'Productos farmacéuticos y veterinarios' },
  { num: 6,  desc: 'Metales comunes y sus aleaciones' },
  { num: 7,  desc: 'Máquinas y máquinas herramientas' },
  { num: 8,  desc: 'Herramientas e instrumentos de mano' },
  { num: 9,  desc: 'Aparatos científicos, ópticos, informáticos, electrónicos' },
  { num: 10, desc: 'Aparatos médicos y quirúrgicos' },
  { num: 11, desc: 'Aparatos de alumbrado, calefacción, refrigeración' },
  { num: 12, desc: 'Vehículos y medios de transporte' },
  { num: 13, desc: 'Armas de fuego, municiones, explosivos' },
  { num: 14, desc: 'Joyería, relojería, metales preciosos' },
  { num: 15, desc: 'Instrumentos musicales' },
  { num: 16, desc: 'Papel, cartón, artículos de imprenta' },
  { num: 17, desc: 'Caucho, goma, plásticos semielaborados' },
  { num: 18, desc: 'Cuero, artículos de viaje, bolsos' },
  { num: 19, desc: 'Materiales de construcción no metálicos' },
  { num: 20, desc: 'Muebles, espejos, marcos, madera' },
  { num: 21, desc: 'Utensilios del hogar, vidrio, porcelana' },
  { num: 22, desc: 'Cuerdas, redes, tiendas, telas técnicas' },
  { num: 23, desc: 'Hilos y fibras textiles industriales' },
  { num: 24, desc: 'Tejidos y sustitutos; ropa de hogar' },
  { num: 25, desc: 'Prendas de vestir, calzado, sombrerería' },
  { num: 26, desc: 'Encajes, bordados, botones, adornos textiles' },
  { num: 27, desc: 'Alfombras, revestimientos de suelos' },
  { num: 28, desc: 'Juegos, juguetes, artículos deportivos' },
  { num: 29, desc: 'Carne, pescado, aves, conservas, lácteos' },
  { num: 30, desc: 'Café, té, panadería, repostería, condimentos' },
  { num: 31, desc: 'Productos agrícolas, hortícolas, animales vivos' },
  { num: 32, desc: 'Cervezas, aguas, bebidas sin alcohol' },
  { num: 33, desc: 'Bebidas alcohólicas (excepto cervezas)' },
  { num: 34, desc: 'Tabaco, cigarrillos, artículos para fumadores' },
  { num: 35, desc: 'Publicidad, gestión comercial, oficina' },
  { num: 36, desc: 'Seguros, finanzas, inmobiliaria' },
  { num: 37, desc: 'Construcción, reparación, instalación' },
  { num: 38, desc: 'Telecomunicaciones' },
  { num: 39, desc: 'Transporte, logística, almacenamiento' },
  { num: 40, desc: 'Tratamiento de materiales, reciclaje' },
  { num: 41, desc: 'Educación, entretenimiento, deporte, cultura' },
  { num: 42, desc: 'Servicios científicos, tecnológicos, informáticos' },
  { num: 43, desc: 'Restauración, alojamiento temporal' },
  { num: 44, desc: 'Servicios médicos, veterinarios, de belleza' },
  { num: 45, desc: 'Servicios jurídicos, de seguridad, personales' },
];

const provinces = [
  'Buenos Aires', 'Catamarca', 'Chaco', 'Chubut',
  'Ciudad Autónoma de Buenos Aires', 'Córdoba', 'Corrientes',
  'Entre Ríos', 'Formosa', 'Jujuy', 'La Pampa', 'La Rioja',
  'Mendoza', 'Misiones', 'Neuquén', 'Río Negro', 'Salta',
  'San Juan', 'San Luis', 'Santa Cruz', 'Santa Fe',
  'Santiago del Estero', 'Tierra del Fuego', 'Tucumán',
];
---

<BaseLayout
  title="Formulario de Registro de Marca | UnaMarca"
  description="Completá el formulario para iniciar el registro de tu marca ante el INPI Argentina."
  canonicalURL={`${SITE_URL}/formularioregistro`}
>

<div class="fp-page">
  <div class="fp-wrap">

    <header class="fp-header">
      <div class="fp-badge">
        <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M8 1.5L2.5 4v4c0 3.2 2.4 5.8 5.5 6.5 3.1-.7 5.5-3.3 5.5-6.5V4L8 1.5z" fill="currentColor"/></svg>
        INPI Argentina
      </div>
      <h1>Registro de Marca</h1>
      <p>Completá los datos para iniciar el trámite. Nos pondremos en contacto a la brevedad.</p>
    </header>

    <div id="fp-success" class="fp-toast fp-toast--ok" style="display:none">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="9" fill="#22c55e" fill-opacity=".12"/><path d="M6 10.2l2.8 2.8 5.2-5.6" stroke="#16a34a" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <div><strong>¡Formulario enviado!</strong><span>Recibimos tu información y te contactamos a la brevedad.</span></div>
    </div>

    <div id="fp-error" class="fp-toast fp-toast--err" style="display:none">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="9" fill="#ef4444" fill-opacity=".12"/><path d="M10 6.5v4M10 13.5h.01" stroke="#dc2626" stroke-width="1.75" stroke-linecap="round"/></svg>
      <div><strong>No se pudo enviar.</strong><span>Intentá de nuevo o escribinos por WhatsApp.</span></div>
    </div>

    <form id="fp-form" novalidate>

      <!-- MARCA -->
      <div class="fp-card">
        <div class="fp-section-label">Marca</div>
        <div class="fp-grid fp-g2">
          <div class="fp-field">
            <label>Nombre de la Marca <em>*</em></label>
            <input type="text" id="marca-nombre" name="marca-nombre" placeholder="De Casa Florentino" required autocomplete="off" />
          </div>
          <div class="fp-field">
            <label>Tipo de Marca <em>*</em></label>
            <div class="fp-sel">
              <select id="marca-tipo" name="marca-tipo" required>
                <option value="Denominativa" selected>Denominativa</option>
                <option value="Mixta">Mixta</option>
                <option value="Figurativa">Figurativa</option>
                <option value="Otro">Otro</option>
              </select>
            </div>
          </div>
        </div>
      </div>

      <!-- TITULARES -->
      <div class="fp-card">
        <div class="fp-section-label">Titulares</div>
        <div id="fp-titulares"></div>
        <div class="fp-titulares-foot">
          <button type="button" id="fp-add" class="fp-add-btn">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 1v12M1 7h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            Agregar titular
          </button>
          <span id="fp-pct" class="fp-pct"></span>
        </div>
      </div>

      <!-- CLASES -->
      <div class="fp-card">
        <div class="fp-section-label">
          Clases Niza
          <span class="fp-optional">opcional</span>
        </div>
        <div class="fp-clases">
          {nizaClasses.map(c => (
            <label class="fp-clase">
              <input type="checkbox" name="clases" value={c.num} />
              <span class="fp-clase-n">{String(c.num).padStart(2,'0')}</span>
              <span class="fp-clase-d">{c.desc}</span>
            </label>
          ))}
        </div>
      </div>

      <!-- SUBMIT -->
      <div class="fp-submit-row">
        <button type="submit" id="fp-submit">
          <span id="fp-submit-label">Enviar formulario</span>
          <svg id="fp-submit-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <svg id="fp-submit-spin" width="16" height="16" viewBox="0 0 16 16" fill="none" style="display:none"><circle cx="8" cy="8" r="6" stroke="rgba(255,255,255,.3)" stroke-width="2"/><path d="M8 2a6 6 0 0 1 6 6" stroke="white" stroke-width="2" stroke-linecap="round"/></svg>
        </button>
      </div>

    </form>
  </div>
</div>

</BaseLayout>

<script define:vars={{ provinces }}>
  let count = 0;

  const pOpts = provinces.map(p => `<option value="${p}">${p}</option>`).join('');

  function titular(idx) {
    return `
<div class="fp-tit" id="fpt-${idx}" data-idx="${idx}">
  <div class="fp-tit-head">
    <span class="fp-tit-num">Titular <b class="fpt-n">${idx+1}</b></span>
    <button type="button" class="fp-tit-rm" data-t="${idx}">
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M1 1l10 10M11 1L1 11" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/></svg>
    </button>
  </div>

  <div class="fp-tit-body">
    <div class="fp-grid fp-g2">
      <div class="fp-field">
        <label>Tipo de Persona <em>*</em></label>
        <div class="fp-sel">
          <select name="tipo-persona-${idx}" class="fpt-tipo" data-idx="${idx}" required>
            <option value="">Seleccionar…</option>
            <option value="Humana">Humana</option>
            <option value="Juridica">Jurídica</option>
          </select>
        </div>
      </div>
      <div class="fp-field">
        <label class="fpt-nlabel-${idx}">Nombre <em>*</em></label>
        <input type="text" name="nombre-${idx}" placeholder="Nombre completo" required autocomplete="off" />
      </div>
    </div>

    <div class="fp-grid fp-g2 fpt-humana-${idx}" style="display:none">
      <div class="fp-field">
        <label>Género <em>*</em></label>
        <div class="fp-sel">
          <select name="genero-${idx}">
            <option value="">Seleccionar…</option>
            <option>Masculino</option>
            <option>Femenino</option>
            <option>Otro</option>
          </select>
        </div>
      </div>
      <div class="fp-field">
        <label>Estado Civil <em>*</em></label>
        <div class="fp-sel">
          <select name="estado-civil-${idx}" class="fpt-ec" data-idx="${idx}">
            <option value="">Seleccionar…</option>
            <option>Soltero/a</option>
            <option>Casado/a</option>
            <option>Divorciado/a</option>
            <option>Viudo/a</option>
          </select>
        </div>
      </div>
    </div>

    <div class="fpt-conyuge-${idx}" style="display:none">
      <div class="fp-field">
        <label>Nombre del Cónyuge <em>*</em></label>
        <input type="text" name="nombre-conyuge-${idx}" placeholder="Nombre completo del cónyuge" autocomplete="off" />
      </div>
    </div>

    <div class="fp-grid fp-g3">
      <div class="fp-field fp-gcol2">
        <label>CUIT / CUIL <em>*</em></label>
        <input type="text" name="cuit-${idx}" placeholder="20-12345678-9" required autocomplete="off" />
      </div>
      <div class="fp-field">
        <label>Porcentaje % <em>*</em></label>
        <input type="number" name="porcentaje-${idx}" class="fp-pct-inp" min="1" max="100" placeholder="100" required />
      </div>
    </div>

    <div class="fp-field">
      <label>Correo Electrónico <em>*</em></label>
      <input type="email" name="email-${idx}" placeholder="correo@ejemplo.com" required autocomplete="email" />
    </div>

    <div class="fp-domicilio">
      <p class="fp-dom-title">Domicilio Real</p>

      <div class="fp-grid fp-g2">
        <div class="fp-field">
          <label>País <em>*</em></label>
          <input type="text" name="pais-${idx}" value="Argentina" required />
        </div>
        <div class="fp-field">
          <label>Provincia <em>*</em></label>
          <div class="fp-sel"><select name="provincia-${idx}" required><option value="">Seleccionar…</option>${pOpts}</select></div>
        </div>
      </div>
      <div class="fp-grid fp-g2">
        <div class="fp-field">
          <label>Localidad <em>*</em></label>
          <input type="text" name="localidad-${idx}" placeholder="Localidad" required autocomplete="off" />
        </div>
        <div class="fp-field">
          <label>Código Postal <em>*</em></label>
          <input type="text" name="codigo-postal-${idx}" placeholder="C1406" required autocomplete="off" />
        </div>
      </div>
      <div class="fp-grid fp-g2">
        <div class="fp-field">
          <label>Calle <em>*</em></label>
          <input type="text" name="calle-${idx}" placeholder="Av. Corrientes" required autocomplete="off" />
        </div>
        <div class="fp-field">
          <label>Número <em>*</em></label>
          <input type="text" name="numero-${idx}" placeholder="1234" required autocomplete="off" />
        </div>
      </div>
      <div class="fp-grid fp-g2">
        <div class="fp-field">
          <label>Piso</label>
          <input type="text" name="piso-${idx}" placeholder="3" autocomplete="off" />
        </div>
        <div class="fp-field">
          <label>Depto</label>
          <input type="text" name="depto-${idx}" placeholder="A" autocomplete="off" />
        </div>
      </div>
    </div>
  </div>
</div>`;
  }

  function addTitular() {
    const c = document.getElementById('fp-titulares');
    const idx = count++;
    const tmp = document.createElement('div');
    tmp.innerHTML = titular(idx);
    c.appendChild(tmp.firstElementChild);
    wire(idx);
    refresh();
  }

  function wire(idx) {
    document.querySelector(`.fp-tit-rm[data-t="${idx}"]`)
      ?.addEventListener('click', () => { document.getElementById(`fpt-${idx}`)?.remove(); refresh(); });

    document.querySelector(`select[name="tipo-persona-${idx}"]`)
      ?.addEventListener('change', () => { onTipo(idx); onLabel(idx); });

    document.querySelector(`select[name="estado-civil-${idx}"]`)
      ?.addEventListener('change', () => onEc(idx));

    document.querySelector(`input[name="porcentaje-${idx}"]`)
      ?.addEventListener('input', syncPct);
  }

  function onTipo(idx) {
    const v = document.querySelector(`select[name="tipo-persona-${idx}"]`)?.value;
    const isH = v === 'Humana';
    document.querySelectorAll(`.fpt-humana-${idx}`).forEach(el => {
      el.style.display = isH ? '' : 'none';
      el.querySelectorAll('select,input').forEach(f => isH ? f.setAttribute('required','') : f.removeAttribute('required'));
    });
    if (!isH) {
      document.querySelector(`.fpt-conyuge-${idx}`).style.display = 'none';
      document.querySelector(`input[name="nombre-conyuge-${idx}"]`)?.removeAttribute('required');
    }
  }

  function onLabel(idx) {
    const v = document.querySelector(`select[name="tipo-persona-${idx}"]`)?.value;
    const el = document.querySelector(`.fpt-nlabel-${idx}`);
    if (el) el.firstChild.textContent = (v === 'Juridica' ? 'Razón Social' : 'Nombre') + ' ';
  }

  function onEc(idx) {
    const v = document.querySelector(`select[name="estado-civil-${idx}"]`)?.value;
    const row = document.querySelector(`.fpt-conyuge-${idx}`);
    const inp = document.querySelector(`input[name="nombre-conyuge-${idx}"]`);
    if (!row) return;
    const show = v === 'Casado/a';
    row.style.display = show ? '' : 'none';
    show ? inp?.setAttribute('required','') : inp?.removeAttribute('required');
  }

  function syncPct() {
    const el = document.getElementById('fp-pct');
    if (!el) return;
    let t = 0;
    document.querySelectorAll('.fp-pct-inp').forEach(i => { const v = parseFloat(i.value); if (!isNaN(v)) t += v; });
    if (!document.querySelectorAll('.fp-pct-inp').length) { el.textContent=''; return; }
    const ok = Math.abs(t-100) < .01;
    el.textContent = `${t}%${ok ? ' ✓' : ' — debe sumar 100%'}`;
    el.className = `fp-pct ${ok ? 'fp-pct--ok' : 'fp-pct--warn'}`;
  }

  function refresh() {
    const all = document.querySelectorAll('.fp-tit');
    all.forEach((b, i) => {
      const n = b.querySelector('.fpt-n'); if (n) n.textContent = String(i+1);
      const rm = b.querySelector('.fp-tit-rm');
      if (rm) rm.style.visibility = all.length > 1 ? 'visible' : 'hidden';
    });
    syncPct();
  }

  function collect() {
    const fd = new FormData(document.getElementById('fp-form'));
    const marca = { nombre: fd.get('marca-nombre'), tipo: fd.get('marca-tipo') };
    const titulares = Array.from(document.querySelectorAll('.fp-tit')).map(b => {
      const i = b.dataset.idx;
      const tp = fd.get(`tipo-persona-${i}`);
      const ec = fd.get(`estado-civil-${i}`);
      const t = {
        tipoPersona: tp, nombre: fd.get(`nombre-${i}`),
        cuit: fd.get(`cuit-${i}`), porcentaje: parseFloat(fd.get(`porcentaje-${i}`) || '0'),
        email: fd.get(`email-${i}`),
        domicilio: {
          pais: fd.get(`pais-${i}`), provincia: fd.get(`provincia-${i}`),
          localidad: fd.get(`localidad-${i}`), codigoPostal: fd.get(`codigo-postal-${i}`),
          calle: fd.get(`calle-${i}`), numero: fd.get(`numero-${i}`),
          piso: fd.get(`piso-${i}`) || '', depto: fd.get(`depto-${i}`) || '',
        },
      };
      if (tp === 'Humana') {
        t.genero = fd.get(`genero-${i}`); t.estadoCivil = ec;
        if (ec === 'Casado/a') t.nombreConyuge = fd.get(`nombre-conyuge-${i}`);
      }
      return t;
    });
    const clases = Array.from(document.querySelectorAll('input[name="clases"]:checked')).map(c => parseInt(c.value));
    return { marca, titulares, clases };
  }

  async function submit(e) {
    e.preventDefault();
    const form = document.getElementById('fp-form');
    if (!form.checkValidity()) { form.reportValidity(); return; }
    let t = 0;
    document.querySelectorAll('.fp-pct-inp').forEach(i => { const v = parseFloat(i.value); if (!isNaN(v)) t += v; });
    if (Math.abs(t-100) > .01) { alert(`El porcentaje debe sumar 100%. Suma ${t}%.`); return; }

    const btn = document.getElementById('fp-submit');
    const lbl = document.getElementById('fp-submit-label');
    const arr = document.getElementById('fp-submit-arrow');
    const spin = document.getElementById('fp-submit-spin');
    btn.disabled = true; lbl.textContent = 'Enviando'; arr.style.display = 'none'; spin.style.display = '';

    try {
      const res = await fetch('/api/submit-form', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(collect()) });
      const json = await res.json();
      if (!json.success) throw new Error();
      form.style.display = 'none';
      const s = document.getElementById('fp-success'); s.style.display = 'flex';
      s.scrollIntoView({ behavior:'smooth', block:'center' });
    } catch {
      const er = document.getElementById('fp-error'); er.style.display = 'flex';
      er.scrollIntoView({ behavior:'smooth', block:'nearest' });
      btn.disabled = false; lbl.textContent = 'Enviar formulario'; arr.style.display = ''; spin.style.display = 'none';
    }
  }

  document.getElementById('fp-add').addEventListener('click', addTitular);
  document.getElementById('fp-form').addEventListener('submit', submit);
  addTitular();
</script>

<!-- is:global so styles apply to JS-generated HTML too -->
<style is:global>

/* ─── Page ─── */
.fp-page {
  background: #f4f6f9;
  min-height: 100vh;
  padding: 3.5rem 1.25rem 6rem;
}

.fp-wrap {
  max-width: 700px;
  margin: 0 auto;
}

/* ─── Header ─── */
.fp-header { margin-bottom: 2.5rem; }

.fp-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  background: #eff6ff;
  color: #2563eb;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 0.3rem 0.8rem;
  border-radius: 100px;
  margin-bottom: 1rem;
}

.fp-header h1 {
  font-size: clamp(1.75rem, 4vw, 2.5rem);
  font-weight: 800;
  color: #0b1d3a;
  letter-spacing: -0.03em;
  margin-bottom: 0.5rem;
  line-height: 1.1;
}

.fp-header p {
  color: #64748b;
  font-size: 0.9375rem;
  margin: 0;
}

/* ─── Toasts ─── */
.fp-toast {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
  padding: 1rem 1.25rem;
  border-radius: 12px;
  margin-bottom: 1.5rem;
  font-size: 0.875rem;
  line-height: 1.5;
}
.fp-toast strong { display: block; font-weight: 600; font-size: 0.9375rem; }
.fp-toast span   { opacity: 0.75; }
.fp-toast svg    { flex-shrink: 0; margin-top: 2px; }
.fp-toast--ok  { background: #f0fdf4; color: #15803d; border: 1px solid #bbf7d0; }
.fp-toast--err { background: #fef2f2; color: #b91c1c; border: 1px solid #fecaca; }

/* ─── Cards ─── */
.fp-card {
  background: #fff;
  border-radius: 18px;
  box-shadow: 0 1px 3px rgba(0,0,0,.05), 0 6px 24px rgba(0,0,0,.05);
  padding: 2rem;
  margin-bottom: 1rem;
}

.fp-section-label {
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #94a3b8;
  margin-bottom: 1.25rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.fp-optional {
  font-size: 0.68rem;
  font-weight: 600;
  color: #cbd5e1;
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 100px;
  padding: 0.15rem 0.6rem;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

/* ─── Grid ─── */
.fp-grid {
  display: grid;
  gap: 1rem;
  margin-bottom: 1rem;
}
.fp-grid:last-child { margin-bottom: 0; }
.fp-g2 { grid-template-columns: 1fr 1fr; }
.fp-g3 { grid-template-columns: 1fr 1fr 1fr; }

@media (max-width: 580px) {
  .fp-g2, .fp-g3 { grid-template-columns: 1fr; }
  .fp-gcol2 { grid-column: auto; }
}
@media (min-width: 581px) {
  .fp-gcol2 { grid-column: span 2; }
}

/* ─── Fields ─── */
.fp-field {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

.fp-field label {
